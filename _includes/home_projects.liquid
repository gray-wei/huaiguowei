<div class="projects">
  {% assign sorted_projects = site.projects | sort: 'importance' %}
  {% assign project_limit = include.limit | default: sorted_projects.size %}
  <div class="home-feature-list home-projects">
    {% assign shown_projects = 0 %}
    {% for project in sorted_projects %}
      {% unless project.homepage_project == false %}
        {% if shown_projects < project_limit %}
          <article class="home-feature-item">
            <div class="home-feature-visual">
              {% if project.image %}
                <div class="home-feature-media" aria-hidden="true">
                  <img class="home-feature-image" src="{{ project.image | relative_url }}" alt="">
                </div>
              {% elsif project.video %}
                <div class="home-feature-media" aria-hidden="true">
                  <video
                    class="home-feature-video"
                    src="{{ project.video | relative_url }}"
                    autoplay
                    muted
                    loop
                    playsinline
                    preload="metadata"
                  ></video>
                </div>
              {% endif %}
            </div>
            <div class="home-feature-copy">
              <h3>
                <a href="{{ project.url | relative_url }}">{{ project.title }}</a>
              </h3>
              {% if project.authors_html %}
                <p class="home-feature-meta">{{ project.authors_html }}</p>
              {% elsif project.authors %}
                <p class="home-feature-meta">{{ project.authors }}</p>
              {% endif %}
              {% if project.advisors_html %}
                <p class="home-feature-advisors">Advisors: {{ project.advisors_html }}</p>
              {% endif %}
              {% if project.status %}
                <p class="home-feature-status">{{ project.status }}</p>
              {% endif %}
              {% unless project.links_enabled == false %}
                <p class="home-feature-links">
                  {% if project.links %}
                    {% for link in project.links %}
                      <a href="{{ link.url }}">{{ link.label }}</a>{% unless forloop.last %} / {% endunless %}
                    {% endfor %}
                  {% else %}
                    {% assign project_page_url = project.project_page | default: project.url %}
                    <a href="{% if project.project_page %}{{ project.project_page }}{% else %}{{ project_page_url | relative_url }}{% endif %}">Project Page</a>
                    /
                    <a href="{{ project.arxiv | default: '#' }}">arXiv</a>
                    /
                    <a href="{{ project.code | default: '#' }}">Code</a>
                  {% endif %}
                </p>
              {% endunless %}
              <p>{{ project.description }}</p>
            </div>
          </article>
          {% assign shown_projects = shown_projects | plus: 1 %}
        {% endif %}
      {% endunless %}
    {% endfor %}
  </div>
</div>
